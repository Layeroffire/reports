    @Test
    void removeVolunteerFromUnit_deletesRelationAndReturnsNoContent() throws Exception {
        Integer relationsBeforeDelete = jdbcTemplate.queryForObject(
                "SELECT COUNT(*) FROM volunteer_unit WHERE unit_id = ? AND volunteer_profile_id = ?",
                Integer.class,
                10L,
                100L
        );

        assertEquals(1, relationsBeforeDelete);

        mockMvc.perform(delete("/voluntary-formation/units/{unitId}/volunteers/{registryId}", 10L, "corr-100"))
                .andExpect(status().isNoContent());

        Integer relationsAfterDelete = jdbcTemplate.queryForObject(
                "SELECT COUNT(*) FROM volunteer_unit WHERE unit_id = ? AND volunteer_profile_id = ?",
                Integer.class,
                10L,
                100L
        );

        assertEquals(0, relationsAfterDelete);
        verify(volunteerRegistryService).removeVolunteerFromUnit("corr-100", "10");
    }

    @Test
    void createVolunteer_createsUnitMemberAndReturnsCreated() throws Exception {
        mockMvc.perform(post("/voluntary-formation")
                        .contentType(MediaType.APPLICATION_JSON)
                        .content("""
                                {
                                  "firstName": "New",
                                  "lastName": "Volunteer",
                                  "birthDate": "1995-05-10",
                                  "rnokpp": "9876543210",
                                  "mobilePhone": "0501234567",
                                  "email": "new.volunteer@test.local",
                                  "town": "Test Town",
                                  "postalCode": "01001",
                                  "region": "Test Region",
                                  "regionDistrict": "Test District",
                                  "street": "Test Street",
                                  "buildingNumber": "15B",
                                  "unitMemberStatus": "UNIT_MEMBER",
                                  "unitId": "10"
                                }
                                """))
                .andExpect(status().isCreated());

        ArgumentCaptor<VolunteerCreateRequest> requestCaptor = ArgumentCaptor.forClass(VolunteerCreateRequest.class);
        verify(volunteerRegistryService).create(requestCaptor.capture());

        VolunteerCreateRequest capturedRequest = requestCaptor.getValue();
        assertEquals("New", capturedRequest.firstName());
        assertEquals("Volunteer", capturedRequest.lastName());
        assertEquals("9876543210", capturedRequest.memberRnokppCode());
        assertEquals("0501234567", capturedRequest.mobilePhone());
        assertEquals("new.volunteer@test.local", capturedRequest.email());
        assertEquals("10", capturedRequest.unitId());
        assertEquals("Unit Member", capturedRequest.unitMemberStatus());
        assertEquals("Test Region", capturedRequest.region());
        assertEquals("Test District", capturedRequest.regionDistrict());
        assertEquals("Test Town", capturedRequest.town());
        assertEquals("Test Street", capturedRequest.street());
        assertEquals("15B", capturedRequest.buildingNumber());
        assertEquals("01001", capturedRequest.postCode());
    }



    private void clearDatabase() {
        jdbcTemplate.execute("TRUNCATE TABLE unit_request, event, address, duty_note_member, duty_note, volunteer_unit, users, volunteer_profile, volunteer_contact_info, unit, regions RESTART IDENTITY CASCADE");
    }

    private void loadSql(String path) {
        new ResourceDatabasePopulator(new ClassPathResource(path))
                .execute(jdbcTemplate.getDataSource());
    }
