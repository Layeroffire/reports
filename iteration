List<Object> commands =
        Arrays.asList(
            command.energy(),
            command.waterSupply(),
            command.heating(),
            command.gasSupply(),
            command.sewage(),
            command.medical(),
            command.geriatric(),
            command.preschool(),
            command.generalEducation(),
            command.higherEducation());

public List<ProcessingResult> processAll(List<Object> commands, String communityId) {

    return commands.stream()
        .filter(Objects::nonNull)
        .map(cmd -> process(cmd, communityId, true))
        .toList();
  }
